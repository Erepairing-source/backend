# eRepairing Backend - copy to .env and set values

# Database (required for app)
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/erepairingnew?charset=utf8mb4

# Security (change in production)
SECRET_KEY=your-secret-key-change-in-production

# CORS - frontend origins (comma-separated in production)
# Local: CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Production: CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ALLOWED_HOSTS (comma-separated; production: your API host)
# Production: ALLOWED_HOSTS=xxx.execute-api.region.amazonaws.com,yourapp.com
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Email - OTP, set-password, forgot-password (optional; if SMTP not set, sends are skipped)
#
# Hostinger (Webmail / business email): use smtp.hostinger.com
# Option A — SSL (recommended): port 465 + implicit SSL
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465
#   SMTP_USER=noreply@erepairing.com
#   SMTP_PASSWORD=<your mailbox password — put only in .env, never commit>
#   SMTP_FROM_EMAIL=noreply@erepairing.com
#   SMTP_USE_SSL=true
#   SMTP_USE_TLS=false
# Option B — STARTTLS: port 587
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=587
#   SMTP_USE_SSL=false
#   SMTP_USE_TLS=true
#
# Active Hostinger / noreply mailbox (copy to .env — set SMTP_PASSWORD locally, never commit .env)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@erepairing.com
SMTP_PASSWORD=your-mailbox-password
SMTP_FROM_EMAIL=noreply@erepairing.com
# Optional display name shown in inbox (recommended)
SMTP_FROM_NAME=eRepairing
# Optional reply destination (recommended: support/shared inbox)
# SMTP_REPLY_TO=hello@erepairing.com
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# Public URL of your web app (used in ALL email links: verify-email, set-password, etc.)
# REQUIRED in production — if this stays localhost, users will get localhost links in email.
# Example production: https://www.erepairing.com (no trailing slash)
FRONTEND_URL=http://localhost:3000
SET_PASSWORD_TOKEN_EXPIRE_HOURS=24

# Optional: protect POST /api/v1/jobs/reminders/run (cron). Generate a long random string.
# REMINDER_JOB_SECRET=

# Production load: prefer several smaller API tasks behind a load balancer over one huge VM.
# RDS max_connections must exceed (workers per task × tasks × ~30) if pools are saturated — tune pool_size in code if needed.
#
# OEM warranty background sync (off by default). With Docker/Uvicorn --workers N, only one worker
# runs sync (POSIX flock). Override lock file path if /tmp is not writable (e.g. ECS).
# OEM_WARRANTY_SYNC_ENABLED=false
# OEM_SYNC_LOCK_PATH=/tmp/erepairing_oem_sync.lock

# Optional: Redis, AWS, Twilio, Maps, OpenAI - set if you use those features
# REDIS_URL=redis://localhost:6379/0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_KEY=
# TWILIO_ACCOUNT_SID=
# MAPBOX_ACCESS_TOKEN=
# OPENAI_API_KEY=
# Google Gemini — floating Role Assistant (/ai/role-assistant) + customer chatbot (/ai/chatbot/message)
# Prefer this over OpenAI for those endpoints when set. Never commit real keys; use Google AI Studio.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# Tests (optional - default is SQLite in-memory)
# TEST_DATABASE_URL=mysql+pymysql://root:pass@localhost:3306/erepairing_test
